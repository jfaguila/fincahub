# ============================================================
# FINCAHUB API — Variables de entorno
# Copia este archivo como .env para desarrollo local
# En produccion (Railway), configura estas variables en el panel
# ============================================================

# Base de datos — Railway lo genera automaticamente con PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/fincahub"

# JWT — cualquier texto largo y aleatorio
JWT_SECRET="fincahub-dev-secret-change-in-production"

# Servidor
PORT=3001
NODE_ENV=development

# URL del frontend (Next.js)
FRONTEND_URL="http://localhost:3000"

# ============================================================
# PAYPAL — Configurado en sandbox (modo prueba)
# Cambia a credenciales "Live" cuando vayas a produccion real
# ============================================================
PAYPAL_CLIENT_ID="AQ4PuIZlMMYYYE5kUiq6ih5oG20XsM0ZxjxviluYnoRZrc8eCJhR4uxLwfQWJm-dgom7E_TETPzOmvLN"
PAYPAL_CLIENT_SECRET="EB2QJnNYDLIgCRNT5xYFF2yyOY9_t8U_7ZpVIWMWdGhrl4oG6tsAYwKpQTF0t_ysKfnGxFbSrO7ZigLE"
PAYPAL_PLAN_BASIC="P-48L477991A659943RNG63MAI"
PAYPAL_PLAN_PROFESSIONAL="P-32452481SH018471TNG63ZJY"
PAYPAL_PLAN_URBANIZATION="P-6UD0517694759734ENG634RA"
PAYPAL_WEBHOOK_ID="66Y66492GS423691E"
PAYPAL_MODE="sandbox"
# PAYPAL_MODE="live"  ← descomenta esto en produccion real

# ============================================================
# EMAIL — Zoho Mail con dominio propio (recomendado)
# 1. Crea cuenta gratis en zoho.com/mail → plan Free
# 2. Añade y verifica tu dominio fincahub.com
# 3. Crea el buzón info@fincahub.com
# 4. Activa SMTP: Settings → Mail Accounts → SMTP → Generate Password
# Sin esto, los emails se registran en consola pero no se envian
# ============================================================
MAIL_HOST="smtp.zoho.eu"
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER="info@fincahub.com"
MAIL_PASS="tu_contraseña_smtp_zoho"
MAIL_FROM="FincaHub <info@fincahub.com>"

# Alternativa Gmail (no recomendada para produccion — envia desde @gmail.com)
# MAIL_HOST="smtp.gmail.com"
# MAIL_USER="tu@gmail.com"
# MAIL_PASS="xxxx xxxx xxxx xxxx"

# ============================================================
# BACKUPS — Directorio donde se guardan los backups locales
# En produccion (Railway), los backups se guardan en /tmp
# ============================================================
BACKUP_DIR="/tmp/fincahub-backups"

# ============================================================
# BACKUPS EN CLOUDFLARE R2 (almacenamiento en la nube)
# Bucket: fincahub-backups
# Panel: https://dash.cloudflare.com → R2 → fincahub-backups
# ============================================================
AWS_S3_BUCKET="fincahub-backups"
AWS_ACCESS_KEY_ID="7a2eeda7983f61a808b2b0c0b3db85b4"
AWS_SECRET_ACCESS_KEY="0ef854ded561ae6426731ff057ff0c22530dc1a2db2067a396bab287e3eefbee"
AWS_S3_REGION="auto"
AWS_S3_ENDPOINT="https://bb21cc0b1508d24f3bc83647a90aaf89.r2.cloudflarestorage.com"
